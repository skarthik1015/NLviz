# Normalize all text files to LF in the repo (cross-platform friendly)
* text=auto eol=lf

# --- Code / configs (explicit, keeps them LF) ---
*.py        text eol=lf
*.pyi       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.env       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf

# Terraform
*.tf        text eol=lf
*.tfvars    text eol=lf
*.hcl       text eol=lf

# Docker
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# Web
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# --- Windows scripts should stay CRLF on checkout ---
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# --- Shell scripts should stay LF ---
*.sh        text eol=lf

# --- Binary files (never modify line endings) ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.7z        binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary